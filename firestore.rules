rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /price_tracking/{trackerId} {
      allow read, write: if true;
    }

    match /wishlist/{wishlistId} {
      allow read, write: if true;
    }

    match /presence/{sessionId} {
      allow read, write: if true;
    }
  }
}
